{
  "name": "openrouter-frontier-remotion",
  "dataset_dir": "artifacts/datasets/qwen25coder-3b-remotion",
  "output_dir": "artifacts/benchmarks/openrouter-frontier-remotion",
  "generation": {
    "max_tokens": 4000,
    "temperature": 0.2,
    "top_p": 0.95,
    "top_k": 40,
    "seed": 42
  },
  "evaluation": {
    "run_render": true,
    "max_cases": 6,
    "max_render_seconds": 120,
    "allowed_render_regression": 0.05,
    "min_loss_delta": 0.01,
    "tie_loss_delta": 0.003,
    "metric_weights": {
      "compile": 0.3,
      "component_export": 0.15,
      "required_snippets": 0.25,
      "forbidden_snippets": 0.05,
      "render": 0.25
    },
    "runtime": {
      "runner_dir": "runner",
      "composition_id": "EvalComp",
      "render_mode": "still",
      "render_frame": 15,
      "output_extension": "png"
    }
  },
  "openrouter": {
    "api_base": "https://openrouter.ai/api/v1",
    "api_key_env": "OPENROUTER_API_KEY",
    "site_url": "https://github.com/SebastianBoehler/autoresearch_remotion_finetune",
    "app_name": "autoresearch-remotion-finetune",
    "timeout_seconds": 240,
    "route": null,
    "transforms": [],
    "reasoning_effort": "minimal",
    "reasoning_exclude": true
  },
  "targets": [
    {
      "name": "openai-gpt-5-4-mini",
      "backend": "openrouter",
      "model": "openai/gpt-5.4-mini"
    },
    {
      "name": "openai-gpt-5-4-pro",
      "backend": "openrouter",
      "model": "openai/gpt-5.4-pro"
    },
    {
      "name": "openai-gpt-5-4",
      "backend": "openrouter",
      "model": "openai/gpt-5.4"
    },
    {
      "name": "openai-gpt-5-3-codex",
      "backend": "openrouter",
      "model": "openai/gpt-5.3-codex"
    }
  ]
}
